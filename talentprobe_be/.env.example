MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_username
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=talent_probe
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# File storage backend: local (development) or spaces (production)
STORAGE_BACKEND=local

# DigitalOcean Spaces settings (required when STORAGE_BACKEND=spaces)
SPACES_BUCKET=your-space-bucket
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_KEY=your_spaces_access_key
SPACES_SECRET=your_spaces_secret_key
# Optional CDN/domain base URL (e.g. https://cdn.example.com)
SPACES_CDN_URL=

# Optional: frontend origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

